NEXT_PUBLIC_YANDEX_MAPS_API_KEY=replace-with-your-yandex-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-long-random-secret
# Optional cookie override:
# true  -> always Secure cookies (HTTPS only)
# false -> allow HTTP cookies (required for no-domain HTTP mode)
# ADMIN_COOKIE_SECURE=false

# Domain for Caddy/HTTPS (example: map.example.com)
DOMAIN=example.com
